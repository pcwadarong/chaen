#!/bin/sh

echo "🔧 Running pnpm exec lint-staged..."
pnpm exec lint-staged
RESULT=$?

if [ $RESULT -ne 0 ]; then
  echo "❌ Format failed. Commit aborted."
  exit 1
fi

echo "▶ Running staged tests..."
pnpm run test:staged
RESULT=$?

if [ $RESULT -ne 0 ]; then
  echo "❌ Staged tests failed. Commit aborted."
  exit 1
fi

echo "✅ Format and staged tests passed. Commit allowed."
exit 0
