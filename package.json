{
  "name": "chaen",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n next,panda -c blue,magenta \"pnpm dev:next\" \"pnpm panda:watch\"",
    "dev:next": "next dev",
    "panda:watch": "concurrently -k -n codegen,css -c magenta,cyan \"panda codegen --watch\" \"panda cssgen --watch --outfile styled-system/styles.css\"",
    "panda:codegen": "panda codegen && panda cssgen --outfile styled-system/styles.css",
    "prepare": "pnpm panda:codegen",
    "build": "next build",
    "start": "next start",
    "commit": "cz",
    "lint": "eslint .",
    "check-types": "next typegen && tsc --noEmit",
    "typecheck": "pnpm run check-types",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "pnpm run test:vitest && pnpm run test:browser",
    "test:vitest": "pnpm run test:node && pnpm run test:dom:model && pnpm run test:dom:ui && pnpm run test:dom:heavy",
    "test:node": "node scripts/run-vitest-group.mjs node",
    "test:dom:model": "node scripts/run-vitest-group.mjs dom-model",
    "test:dom:ui": "node scripts/run-vitest-group.mjs dom-ui",
    "test:dom:heavy": "node scripts/run-vitest-group.mjs dom-heavy",
    "test:browser": "playwright test",
    "test:browser:smoke": "playwright test tests/browser/home.smoke.spec.ts tests/browser/public-page-pdf-download.spec.ts",
    "test:browser:headed": "playwright test --headed",
    "test:browser:debug": "playwright test --debug",
    "test:browser:install": "playwright install chromium",
    "test:coverage": "rm -rf coverage && mkdir -p coverage/.tmp && vitest run --coverage --coverage.reporter=json-summary --coverage.reporter=text-summary",
    "test:watch": "vitest",
    "postinstall": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css,scss}": [
      "prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-customizable",
      "config": ".cz-config.cjs"
    }
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.57.4",
    "googleapis": "^171.4.0",
    "gsap": "^3.13.0",
    "katex": "^0.16.44",
    "mermaid": "^11.13.0",
    "next": "^15.5.3",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "open-graph-scraper": "^6.11.0",
    "postprocessing": "^6.39.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "rehype-pretty-code": "^0.14.3",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.1",
    "three": "^0.180.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@pandacss/dev": "^1.9.0",
    "@playwright/test": "^1.59.1",
    "@svgr/webpack": "^8.1.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.4.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.27",
    "commitizen": "^4.3.1",
    "concurrently": "^9.2.1",
    "cz-customizable": "^7.5.1",
    "eslint": "^9.35.0",
    "eslint-config-next": "^15.5.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "jsdom": "^27.0.0",
    "lint-staged": "^16.1.6",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.43.0",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.18.3"
}
